<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="page-wrap">
  <div class="page-content">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><i class="fas fa-edit"></i> Edit Job</h1>
      <a href="/jobs/manage" class="btn btn-outline">← Back</a>
    </div>
    <div class="form-card">
      <form action="/jobs/<%= job._id %>?_method=PUT" method="POST">
        <div class="form-grid">
          <div class="form-group">
            <label>Job Title *</label>
            <input type="text" name="title" value="<%= job.title %>" required maxlength="200" />
          </div>
          <div class="form-group">
            <label>Location</label>
            <input type="text" name="location" value="<%= job.location %>" maxlength="200" />
          </div>
          <div class="form-group">
            <label>Job Type</label>
            <select name="jobType">
              <% ['Full-time','Part-time','Internship','Contract','Freelance'].forEach(t => { %>
                <option value="<%= t %>" <%= job.jobType === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Category</label>
            <select name="category">
              <% ['Technology','Finance','Marketing','Design','Sales','HR','Operations','Other'].forEach(c => { %>
                <option value="<%= c %>" <%= job.category === c ? 'selected' : '' %>><%= c %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Salary / CTC</label>
            <input type="text" name="salary" value="<%= job.salary || '' %>" />
          </div>
          <div class="form-group">
            <label>Application Deadline</label>
            <input type="date" name="deadline" value="<%= job.deadline ? new Date(job.deadline).toISOString().split('T')[0] : '' %>" />
          </div>
        </div>
        <div class="form-group">
          <label>Skills Required</label>
          <input type="text" name="skills" value="<%= job.skills ? job.skills.join(', ') : '' %>" />
        </div>
        <div class="form-group">
          <label>Job Description *</label>
          <textarea name="description" rows="5" maxlength="5000" required><%= job.description %></textarea>
        </div>
        <div class="form-group">
          <label>Requirements</label>
          <textarea name="requirements" rows="4" maxlength="3000"><%= job.requirements || '' %></textarea>
        </div>
        <div class="form-group">
          <label>Job Status</label>
          <label class="toggle-label">
            <input type="checkbox" name="isOpen" <%= job.isOpen ? 'checked' : '' %> />
            <span>Open for Applications</span>
          </label>
        </div>
        <div class="form-actions">
          <a href="/jobs/manage" class="btn btn-outline">Cancel</a>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>
</body></html>
