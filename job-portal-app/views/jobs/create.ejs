<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="page-wrap">
  <div class="page-content">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <h1><i class="fas fa-plus-circle"></i> Post a New Job</h1>
      <a href="/jobs/manage" class="btn btn-outline">← Back</a>
    </div>
    <div class="form-card">
      <form action="/jobs" method="POST">
        <div class="form-grid">
          <div class="form-group">
            <label>Job Title *</label>
            <input type="text" name="title" placeholder="e.g. Frontend Developer" required maxlength="200" />
          </div>
          <div class="form-group">
            <label>Location</label>
            <input type="text" name="location" placeholder="e.g. Bangalore / Remote" maxlength="200" />
          </div>
          <div class="form-group">
            <label>Job Type</label>
            <select name="jobType">
              <% ['Full-time','Part-time','Internship','Contract','Freelance'].forEach(t => { %>
                <option value="<%= t %>"><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Category</label>
            <select name="category">
              <% ['Technology','Finance','Marketing','Design','Sales','HR','Operations','Other'].forEach(c => { %>
                <option value="<%= c %>"><%= c %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Salary / CTC (optional)</label>
            <input type="text" name="salary" placeholder="e.g. ₹8 LPA or Not disclosed" />
          </div>
          <div class="form-group">
            <label>Application Deadline (optional)</label>
            <input type="date" name="deadline" />
          </div>
        </div>
        <div class="form-group">
          <label>Skills Required (comma-separated)</label>
          <input type="text" name="skills" placeholder="e.g. React, Node.js, MongoDB" />
        </div>
        <div class="form-group">
          <label>Job Description *</label>
          <textarea name="description" rows="5" maxlength="5000" required placeholder="Describe the role, responsibilities, and what you're looking for..."></textarea>
        </div>
        <div class="form-group">
          <label>Requirements (optional)</label>
          <textarea name="requirements" rows="4" maxlength="3000" placeholder="List required qualifications, experience, certifications..."></textarea>
        </div>
        <div class="form-actions">
          <a href="/jobs/manage" class="btn btn-outline">Cancel</a>
          <button type="submit" class="btn btn-primary">Post Job</button>
        </div>
      </form>
    </div>
  </div>
</div>
</body></html>
