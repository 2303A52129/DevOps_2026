<%- include('../partials/head') %>
<div class="auth-container">
  <div class="auth-card auth-card-wide">
    <div class="auth-logo"><i class="fas fa-briefcase"></i> JobPortal</div>
    <h2>Create Account</h2>
    <p class="auth-subtitle">Choose your role to get started</p>
    <%- include('../partials/flash') %>

    <!-- Role Selector -->
    <div class="role-selector">
      <div class="role-option" id="opt-candidate" onclick="selectRole('candidate')">
        <i class="fas fa-user-tie"></i>
        <strong>Candidate</strong>
        <span>Browse & apply for jobs</span>
      </div>
      <div class="role-option" id="opt-recruiter" onclick="selectRole('recruiter')">
        <i class="fas fa-building"></i>
        <strong>Recruiter</strong>
        <span>Post jobs & hire talent</span>
      </div>
    </div>

    <form action="/auth/register" method="POST">
      <input type="hidden" name="role" id="roleInput" value="candidate" />

      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="name" placeholder="John Doe" required />
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="you@example.com" required />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Min 6 characters" required />
      </div>
      <div class="form-group">
        <label>Confirm Password</label>
        <input type="password" name="confirmPassword" placeholder="Repeat password" required />
      </div>

      <!-- Recruiter-only fields -->
      <div id="recruiter-fields" style="display:none;">
        <div class="form-group">
          <label>Company Name <span class="required">*</span></label>
          <input type="text" name="company" placeholder="e.g. Infosys" />
        </div>
        <div class="form-group">
          <label>Company Website (optional)</label>
          <input type="url" name="companyWebsite" placeholder="https://yourcompany.com" />
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-block">Create Account</button>
    </form>
    <p class="auth-switch">Already have an account? <a href="/auth/login">Login here</a></p>
  </div>
</div>
<script>
  function selectRole(role) {
    document.getElementById('roleInput').value = role;
    document.getElementById('opt-candidate').classList.toggle('active', role === 'candidate');
    document.getElementById('opt-recruiter').classList.toggle('active', role === 'recruiter');
    document.getElementById('recruiter-fields').style.display = role === 'recruiter' ? 'block' : 'none';
  }
  // Default: candidate selected
  selectRole('candidate');
</script>
</body></html>
