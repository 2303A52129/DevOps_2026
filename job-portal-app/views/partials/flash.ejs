<% if (messages.success && messages.success.length > 0) { %>
  <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= messages.success[0] %></div>
<% } %>
<% if (messages.error && messages.error.length > 0) { %>
  <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %></div>
<% } %>
