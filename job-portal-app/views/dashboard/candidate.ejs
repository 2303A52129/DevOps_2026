<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="page-wrap">
  <div class="page-content">
    <%- include('../partials/flash') %>
    <div class="page-header">
      <div>
        <h1>Welcome, <%= currentUser.name %>! 👋</h1>
        <p class="page-sub">Track your job applications here</p>
      </div>
      <a href="/jobs" class="btn btn-primary"><i class="fas fa-search"></i> Browse Jobs</a>
    </div>

    <div class="stats-grid">
      <div class="stat-card stat-blue">
        <div class="stat-icon"><i class="fas fa-paper-plane"></i></div>
        <div class="stat-info"><h3><%= stats.totalApps %></h3><p>Total Applied</p></div>
      </div>
      <div class="stat-card stat-yellow">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-info"><h3><%= stats.pending %></h3><p>Pending</p></div>
      </div>
      <div class="stat-card stat-green">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info"><h3><%= stats.accepted %></h3><p>Accepted</p></div>
      </div>
      <div class="stat-card stat-red">
        <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
        <div class="stat-info"><h3><%= stats.rejected %></h3><p>Rejected</p></div>
      </div>
    </div>

    <div class="section-card">
      <h2><i class="fas fa-history"></i> Recent Applications</h2>
      <% if (recentApps.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-folder-open"></i>
          <p>No applications yet. <a href="/jobs">Browse jobs to get started!</a></p>
        </div>
      <% } else { %>
        <table class="data-table">
          <thead><tr><th>Position</th><th>Company</th><th>Location</th><th>Status</th><th>Applied</th></tr></thead>
          <tbody>
            <% recentApps.forEach(app => { %>
              <tr>
                <td><strong><%= app.job ? app.job.title : 'N/A' %></strong></td>
                <td><%= app.job ? app.job.company : '-' %></td>
                <td><%= app.job ? app.job.location : '-' %></td>
                <td><span class="status-badge status-<%= app.status.toLowerCase() %>"><%= app.status %></span></td>
                <td><%= new Date(app.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <a href="/applications/my" class="view-all">View all applications →</a>
      <% } %>
    </div>
  </div>
</div>
</body></html>
